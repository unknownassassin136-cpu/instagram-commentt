PORT=3000
VERIFY_TOKEN=your_meta_verify_token

# Token Provider Configuration
# Supported options: JSON, SQLITE, API
TOKEN_PROVIDER_TYPE=JSON

# Set this if using JSON token provider (default)
JSON_STORAGE_PATH=./tokens.json

# Set this if using SQLITE token provider
SQLITE_DB_PATH=./database.sqlite

# Set this if using API token provider
TOKEN_API_ENDPOINT=https://your-api.com/token
